# LLM API Configuration
# These are used by the GEO Audit Agent to query models for citation analysis.

# The base URL for the LLM proxy or direct provider (OpenAI compatible)
# Default is set to a local proxy, but can be changed to https://api.openai.com/v1 etc.
ANTHROPIC_BASE_URL=http://localhost:20128/v1

# Your API Key for the selected provider
ANTHROPIC_AUTH_TOKEN=sk_9router

# App Security
API_SECRET_KEY=dev_default_key
